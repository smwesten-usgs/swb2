# Auto-detect text files and normalize to LF in the repo
* text=auto

# Source code — LF in repo, native on checkout
*.F90 text eol=lf
*.f90 text eol=lf
*.c text eol=lf
*.h text eol=lf
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.ctl text eol=lf
*.csv text eol=lf
*.tsv text eol=lf
*.sh text eol=lf
*.bat text eol=crlf

# Build/config files
meson.build text eol=lf
meson_options.txt text eol=lf
CMakeLists.txt text eol=lf
*.cmake text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf

# Binary files — do not touch
*.png binary
*.svg binary
*.pdf binary
*.nc binary
*.exe binary
*.xls binary
*.xlsx binary
*.asc binary
*.gch binary
*.ipynb binary
